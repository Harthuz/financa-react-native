# Credenciais do PostgreSQL (docker-compose)
POSTGRES_USER=finance
POSTGRES_PASSWORD=finance
POSTGRES_DB=finance

# URL da API para o app Expo em desenvolvimento.
# - Web/iOS simulator: http://localhost:3001 (padrão, pode omitir)
# - Emulador Android: http://10.0.2.2:3001 (padrão no Android, pode omitir)
# - Dispositivo físico: use o IP da sua máquina na rede local
# EXPO_PUBLIC_API_URL=http://192.168.0.10:3001
